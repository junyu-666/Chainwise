# 数据库（进度持久化用；本地不配置时进度仅存于浏览器 localStorage）
DATABASE_URL="postgresql://chainwise:password@db:5432/chainwise"
DB_PASSWORD="password"

# BNB 测试网（仅只读查询用）
NEXT_PUBLIC_BNB_TESTNET_RPC="https://data-seed-prebsc-1-s1.bnbchain.org:8545"
NEXT_PUBLIC_BNB_TESTNET_CHAIN_ID=97
NEXT_PUBLIC_BNB_EXPLORER="https://testnet.bscscan.com"

# 演示合约地址（部署到 BNB 测试网后填入）
NEXT_PUBLIC_DEMO_CONTRACT_ADDRESS=""

# 站点 URL（用于 sitemap、robots、OG、结构化数据）
NEXT_PUBLIC_SITE_URL="https://chainwise.example"

# WalletConnect / Reown 项目 ID（钱包扫码连接必需）
# 去 https://cloud.reown.com 免费注册一个项目获取
NEXT_PUBLIC_REOWN_PROJECT_ID=""

# 可选：隐私友好的分析（Umami / Plausible 等），不配置则不加载
NEXT_PUBLIC_ANALYTICS_SRC=""
NEXT_PUBLIC_ANALYTICS_WEBSITE_ID=""
